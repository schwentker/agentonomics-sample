# Anthropic API Key for Claude models (required)
ANTHROPIC_API_KEY=your_api_key_here

# Model Configuration (optional - CLI args override these)
# BENCHMARK_MODEL=claude-sonnet-4-5-20250922
# BENCHMARK_TEMPERATURE=1.0
# BENCHMARK_TOP_P=
# BENCHMARK_TOP_K=
# BENCHMARK_MAX_TOKENS=

# Paths (optional)
# BENCHMARK_MCP_CONFIG=mcp.json
# BENCHMARK_OUTPUT=

# Behavior (optional)
# BENCHMARK_SKIP_VALIDATION=false
